# COZE_API_TOKEN: Coze Personal Access Token used to run Workflow OpenAPI calls.
COZE_API_TOKEN="MY_COZE_PERSONAL_ACCESS_TOKEN"

# COZE_WORKFLOW_ID: Default Coze Workflow ID for statistics AI.
COZE_WORKFLOW_ID="MY_COZE_WORKFLOW_ID"

# Optional: use different workflows for report generation and chat.
COZE_POLICY_WORKFLOW_ID=""
COZE_CHAT_WORKFLOW_ID=""

# Optional: Coze China OpenAPI base URL.
COZE_API_BASE="https://api.coze.cn"

# Optional: default is "object"; set to "string" only if your workflow API expects a JSON string.
COZE_PARAMETERS_FORMAT="object"

# Optional: only fill these if your Coze workflow requires them.
COZE_BOT_ID=""
COZE_APP_ID=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
